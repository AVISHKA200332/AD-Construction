# Copy this file to .env and fill in the values

# Server
PORT=5000

# MongoDB
# If not set, the app will fall back to: mongodb://127.0.0.1:27017/ad_construction

# Example for LOCAL MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/ad_construction

# Example for MongoDB Atlas (SRV). If you see DNS/SRV errors (ENOTFOUND _mongodb._tcp...),
# use the STANDARD (non-SRV) connection string from Atlas instead (see below).
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Example for MongoDB Atlas (STANDARD, non-SRV) — avoids SRV DNS lookups
# Get this from Atlas by selecting "Connect > Drivers > Standard connection string (not SRV)"
# MONGODB_URI=mongodb://host1:27017,host2:27017,host3:27017/<dbname>?replicaSet=<rs>&ssl=true&authSource=admin

# Optional explicit DB name when your URI does not include one
# DB_NAME=ad_construction

# JWT
JWT_SECRET=change-this-to-a-strong-secret
